# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ImageKit.io (Imagens - fotos de perfil, posts, galeria)
VITE_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
VITE_IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key

# Cloudflare R2 (Vídeos e Áudios)
VITE_R2_ACCOUNT_ID=your_r2_account_id
VITE_R2_ACCESS_KEY_ID=your_r2_access_key
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
VITE_R2_BUCKET_NAME=feconecta-media
VITE_R2_PUBLIC_URL=https://media.your-domain.com
